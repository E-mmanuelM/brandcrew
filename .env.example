# ============================================
# BrandCrew — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. It's already in .gitignore.
# ============================================

# --- Anthropic (Claude) ---
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Supabase ---
# 1. Create a free project at: https://supabase.com/
# 2. Go to: Project Settings → API
# 3. Copy the URL and the service_role key (not the anon key)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=your-service-role-key-here

# --- Telegram Bot ---
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow the prompts to create your bot
# 3. BotFather will give you a token — paste it below
# 4. To get your user ID: search for @userinfobot on Telegram, send /start, copy the ID
# 5. Multiple approved IDs can be comma-separated: 123456789,987654321
TELEGRAM_BOT_TOKEN=your-bot-token-here
APPROVED_TELEGRAM_IDS=your-telegram-user-id

# --- GitHub (optional — for snapshot script) ---
# Only needed if you want automatic git commits of VPS outputs
# Create a Personal Access Token at: https://github.com/settings/tokens
# Select "repo" scope
GITHUB_PAT=ghp_your-token-here

# --- Project Paths ---
# Where the project lives on your VPS (default works for most setups)
PROJECT_DIR=/projects/brandcrew

# --- Optional ---
# LOG_LEVEL=info
# NODE_ENV=production
